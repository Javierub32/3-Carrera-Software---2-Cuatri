<file path="deployment.yml">
apiVersion: apps/v1
kind: Deployment
metadata:
  name: webapp
spec:
  replicas: 2
  selector:
    matchLabels:
      app: webapp
  template:
    metadata:
      labels:
        app: webapp
    spec:
      containers:
      - name: webapp
        image: webapp:latest
        imagePullPolicy: Never            
        env:                                
        - name: APP_ENV
          value: "production"

---

apiVersion: v1
kind: Service
metadata:
  name: webapp-service
spec:
  selector:
    app: webapp
  ports:
  - port: 80                                # Puerto del Service dentro del clúster
    targetPort: 5000                         # Puerto del contenedor
    nodePort: 30080                         # Solo para NodePort (rango 30000-32767)
  type: NodePort                           # ClusterIP | NodePort | LoadBalancer
</file>

<file path="docker-compose.yml">
services:
  web:
    image: webapp:latest               # Usar imagen existente
    container_name: webapp            # Nombre personalizado del contenedor
    environment:
      APP_ENV: development                      # Variable de entorno directa
    volumes:
      - ./logs:/app/logs  # Bind mount de solo lectura
    networks:
      - appnet                    # Conectar a una red concreta
    restart: always                     # Política de reinicio

  proxy:
    image: nginx:alpine               # Usar imagen existente
    container_name: proxy            # Nombre personalizado del contenedor
    ports:
      - "80:80"           # Mapeo de puertos
    depends_on:
      - web                      # Esperar a que ese servicio inicie
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/conf.d/default.conf:ro  # Bind mount de solo lectura
    networks:
      - appnet                    # Conectar a una red concreta
    restart: always                # Política de reinicio


networks:
  appnet:
</file>

<file path="Dockerfile">
FROM webapp-base:latest

WORKDIR /app

COPY ./app/requirements.txt .

RUN pip install -r requirements.txt

COPY ./app .

EXPOSE 5000

CMD ["flask", "run",  "--host=0.0.0.0",  "--port=5000"]
</file>

<file path="nginx/nginx.conf">
server {
    listen 80;
    location / {
        proxy_pass       http://web:5000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
</file>

</files>
