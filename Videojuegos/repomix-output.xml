import pygame
import pymunk
import pymunk.pygame_util
import math

PX_M = 5 # 5px por metro (PX/M)
M_PX = 1.0 / PX_M
def crearCirculo(space, masa=0.5, radio=5, friction=-1, elasticity=-1, posX=1, posY=1, velX=0, velY=0):
	radioF = radio * PX_M
	momento = (2 / 5) * masa * (radioF ** 2)

	body = pymunk.Body(masa, momento)
	body.position = (posX, posY)
	body.velocity = (velX, velY)

	shape = pymunk.Circle(body, radioF)
	if friction != -1: shape.friction = friction
	if elasticity != -1: shape.elasticity = elasticity
	
	space.add(body, shape)

	return body, shape
