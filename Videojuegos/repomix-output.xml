    tk.Button(frame, text="Iniciar Simulación Realista", command=iniciar_simulacion,
              bg="#4CAF50", fg="white", font=("Arial", 10, "bold"), padx=10, pady=5).grid(row=len(params), column=0, columnspan=2, pady=18)
    
